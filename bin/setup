#!/usr/bin/env bash

# OpenCode Setup Script
# This script bootstraps OpenCode tool for a git repository.
#
# Requirements:
#  • Git, curl, and a bash-compatible shell

# ---

# This line is often referred to as the "Bash Unofficial Strict Mode"
#
# -e (errexit): Tells the script to exit immediately if a command exits with a non-zero status
#               (indicates an error). Without this, Bash keeps running the next line even if the
#               previous command failed.
# -i (nounset): Causes the script to exit if you try to use a variable that hasn't been defined.
#               This prevents disasters like "rm -rf /$DIR" if $DIR happens to be empty.
# -o pipefail: Ensures that if any command in a pipeline fails (e.g., step1 | step2 | step3), the whole
#              pipeline returns a failure code. Normally, Bash only cares if the last command in the pipe worked.
set -euo pipefail

# Requires Bash 4.2+ for associative arrays and global declarations.
if (( BASH_VERSINFO[0] < 4 )) || { (( BASH_VERSINFO[0] == 4 )) && (( BASH_VERSINFO[1] < 2 )); }
then
    echo "Error: Requires Bash 4.2 or higher." >&2
    echo "Current version: $BASH_VERSION" >&2
    exit 1
fi

# Phase 1: Resolve project root — clone to temp if running remotely
SCRIPT_SRC="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/.." 2>/dev/null && pwd)" || true

CLEANUP_TMP=false
if [[ -f "$SCRIPT_SRC/src/utils/_logger.sh" ]]
then
    ROOT_DIR="$SCRIPT_SRC"
else
    ROOT_DIR=$(mktemp -d)
    git clone --depth 1 \
        https://github.com/DuckKota/OpenCode-Bootstrapper.git \
        "$ROOT_DIR"
    CLEANUP_TMP=true
    trap '[[ "$CLEANUP_TMP" == "true" ]] && rm -rf "$ROOT_DIR"' EXIT INT TERM
fi

# Load helpers
source "$ROOT_DIR/src/utils/_logger.sh"
source "$ROOT_DIR/src/utils/_utils.sh"

function _ensure_git_project
{
    log::info "Ensuring directory is a Git repository..."
    CWD=$(pwd -P)
    if ! util::is_git_project "$CWD"
    then
        log::error "Not a Git repository: $CWD"
        log::error "Please run this script in the root of a Git project."
        exit 1
    fi
    GIT_DIR=$(git -C "$CWD" rev-parse --show-toplevel 2>/dev/null)
    GIT_DIR=$(cd "$GIT_DIR" && pwd -P)
    log::success "Git repository verified! ($GIT_DIR)"
    log::newline
}

function _ensure_openspec_installed
{
    log::info "Ensuring OpenSpec is installed..."
    if ! util::command_exists "openspec"
    then
        log::error "OpenSpec is not installed. Please install OpenSpec and try again."
        log::error "Install: npm install -g @fission-ai/openspec@latest"
        exit 1
    fi
    log::success "OpenSpec verified!"
    log::newline
}

function _ensure_codebase_memory_mcp_installed
{
    log::info "Ensuring codebase-memory-mcp is installed..."
    if ! util::command_exists "codebase-memory-mcp"
    then
        log::error "codebase-memory-mcp is not installed. Please install codebase-memory-mcp and try again."
        log::error "Install: curl -fsSL https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/install.sh | bash -s -- --skip-config"
        exit 1
    fi
    log::success "codebase-memory-mcp verified!"
    log::newline
}

function _ensure_rtk_installed
{
    log::info "Ensuring rtk is installed..."
    if ! util::command_exists "rtk"
    then
        log::error "rtk is not installed. Please install rtk and try again."
        log::error "Install: curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh"
        exit 1
    fi
    log::success "rtk verified!"
    log::newline
}

function _update_gitignore
{
    if [[ ! -f "$GIT_DIR/.gitignore" ]] || ! grep -qF ".opencode/" "$GIT_DIR/.gitignore"
    then
        echo "" >> "$GIT_DIR/.gitignore"
        echo "# Ignore OpenCode" >> "$GIT_DIR/.gitignore"
        echo ".opencode/" >> "$GIT_DIR/.gitignore"
    fi
}

function _init_openspec
{
    log::info "Initializing OpenSpec..."
    openspec init --tools opencode
    log::success "OpenSpec initialized!"
    log::newline
}

function _init_codebase_memory_mcp
{
    log::info "Initializing codebase-memory-mcp..."

    # Ensure we found the codebase-memory-mcp executable
    local codebase_mcp_install_path="$(which codebase-memory-mcp)"
    if [[ -z "$codebase_mcp_install_path" ]]
    then
        log::error "command not found: codebase-memory-mcp"
        return 1
    fi

    # Update the projects AGENTS.md file
    if [[ -f "$GIT_DIR/AGENTS.md" ]]
    then
        local codebase_mcp_agents_content
        codebase_mcp_agents_content=$(cat "$ROOT_DIR/src/instructions/codebase-memory-mcp-agents.md")

        local agents_file="$GIT_DIR/AGENTS.md"
        touch "$agents_file"

        if ! grep -qF "$(echo "$codebase_mcp_agents_content" | head -n1)" "$agents_file"
        then
            local tmp_file
            tmp_file=$(mktemp)
            echo "$codebase_mcp_agents_content" > "$tmp_file"
            echo "" >> "$tmp_file"
            cat "$agents_file" >> "$tmp_file"
            mv "$tmp_file" "$agents_file"
        fi
    else
        cp "$ROOT_DIR/src/instructions/codebase-memory-mcp-agents.md" "$GIT_DIR/AGENTS.md"
    fi

    # This is custom command that I wrote, so I don't care to check that it already exists.
    mkdir -p "$GIT_DIR/.opencode/plugins"
    cp "$ROOT_DIR/src/plugins/CodebaseMemoryReminder.ts" "$GIT_DIR/.opencode/plugins"

    # Update the projects MCP server list
    mkdir -p "$GIT_DIR/.opencode"
    local python_exe
    python_exe="$(util::get_python_exe)"
    if [[ -z "$python_exe" ]]
    then
        log::error "command not found: python3 / python"
        return 1
    fi
    (cd "$GIT_DIR" && "$python_exe" -c "import json, os

file_path = '.opencode/opencode.json'

if not os.path.exists(file_path):
    with open(file_path, 'w') as f:
        f.write('{}')

try:
    with open(file_path, 'r+') as f:
        try:
            data = json.load(f)
        except json.JSONDecodeError:
            data = {}

        payload = {
            'codebase-memory-mcp': {
                'enabled': True,
                'type': 'local',
                'command': ['$codebase_mcp_install_path'],
            }
        }

        if 'mcp' not in data:
            data['mcp'] = payload
        else:
            if 'codebase-memory-mcp' not in data['mcp']:
                data['mcp']['codebase-memory-mcp'] = payload['codebase-memory-mcp']
            else:
                pass

        f.seek(0)
        json.dump(data, f, indent=4)
        f.truncate()
except Exception as e:
    print(f'Error updating file: {e}')
")

    codebase-memory-mcp config set auto_index true  # auto-index on session start
    codebase-memory-mcp config set auto_watch true  # register background git watcher

    log::success "codebase-memory-mcp initialized!"
    log::newline
}

function _init_rtk
{
    log::info "Initializing rtk..."
    echo "n" | rtk init --global --opencode
    log::success "rtk initialized!"
    log::newline
}

function _write_command
{
    if (( $# < 1 ))
    then
        echo "Error: Missing argument." >&2
        exit 1
    fi

    local command_name="$1"
    log::info "Writing $command_name command..."
    if [[ -f "$GIT_DIR/.opencode/commands/$command_name.md" ]]
    then
        local command_current
        command_current=$(cat "$GIT_DIR/.opencode/commands/$command_name.md")
        local command_new
        command_new=$(cat "$ROOT_DIR/src/commands/$command_name.md")
        if [[ "$command_current" == "$command_new" ]]
        then
            log::success "/$command_name command already set up in $GIT_DIR/.opencode/commands/$command_name.md"
            log::newline
        else
            log::warn "Skipping /$command_name command. Different skill by the same name already exists: $GIT_DIR/.opencode/commands/$command_name.md"
            log::newline
        fi
    else
        mkdir -p "$GIT_DIR/.opencode/commands"
        cp "$ROOT_DIR/src/commands/$command_name.md" "$GIT_DIR/.opencode/commands/$command_name.md"
        log::success "/$command_name command written to .opencode/commands/$command_name.md"
        log::newline
    fi
}

function _write_skill
{
    if (( $# < 1 ))
    then
        echo "Error: Missing argument." >&2
        exit 1
    fi

    local skill_name="$1"
    log::info "Writing $skill_name skill..."

    local src_dir="$ROOT_DIR/src/skills/$skill_name"
    local skill_dir="$GIT_DIR/.opencode/skills/$skill_name"

    if [[ ! -d "$src_dir" ]]
    then
        log::error "Skill source not found: $src_dir"
        exit 1
    fi

    if [[ -d "$skill_dir" ]]
    then
        local any_diff=0
        local file rel_path current existing
        while IFS= read -r -d '' file
        do
            rel_path="${file#$src_dir/}"
            current=$(cat "$ROOT_DIR/src/skills/$skill_name/$rel_path")
            existing=$(cat "$skill_dir/$rel_path" 2>/dev/null)
            if [[ "$current" != "$existing" ]]
            then
                any_diff=1
                break
            fi
        done < <(find "$src_dir" -type f -print0)

        if (( any_diff == 0 ))
        then
            log::success "$skill_name skill already set up in $skill_dir"
            log::newline
        else
            log::warn "Skipping $skill_name skill. Different version already exists: $skill_dir"
            log::newline
        fi
        return 0
    fi

    local file rel_path target_file
    while IFS= read -r -d '' file
    do
        rel_path="${file#$src_dir/}"
        target_file="$skill_dir/$rel_path"
        mkdir -p "$(dirname "$target_file")"
        cp "$ROOT_DIR/src/skills/$skill_name/$rel_path" "$target_file"
    done < <(find "$src_dir" -type f -print0)

    log::success "$skill_name skill written to .opencode/skills/$skill_name"
    log::newline
}

function _init_caveman_speak
{
    log::info "Initializing caveman speak..."
    local caveman_content
    caveman_content=$(cat "$ROOT_DIR/src/instructions/caveman.md")

    local agents_file
    agents_file="$HOME/.config/opencode/AGENTS.md"
    mkdir -p "$(dirname "$agents_file")"
    touch "$agents_file"
    if grep -qF "$caveman_content" "$agents_file"
    then
        log::success "Caveman direction already exists in $agents_file"
        log::newline
    else
        local tmp_file
        tmp_file=$(mktemp)
        echo "$caveman_content" > "$tmp_file"
        echo "" >> "$tmp_file"
        cat "$agents_file" >> "$tmp_file"
        mv "$tmp_file" "$agents_file"
        log::success "Caveman speak initialized!"
        log::newline
    fi
}

function _write_commit_message_command
{
    log::info "Writing commit-message command..."
    local repo_command="$GIT_DIR/.opencode/commands/commit-message.md"
    local repo_script="$GIT_DIR/.opencode/scripts/verify-commit"
    local src_command="$ROOT_DIR/src/commands/commit-message.md"
    local src_script="$ROOT_DIR/src/commands/verify-commit"

    if [[ -f "$repo_command" ]] || [[ -f "$repo_script" ]]
    then
        if [[ -f "$repo_command" ]] && [[ -f "$repo_script" ]]
        then
            local current_script new_script
            current_script=$(cat "$repo_script")
            new_script=$(cat "$src_script")

            local current_command new_command
            current_command=$(cat "$repo_command")
            new_command=$(cat "$src_command" | sed "s|<VALIDATE_COMMIT_SCRIPT>|$repo_script|g")

            if [[ "$current_command" == "$new_command" ]] && [[ "$current_script" == "$new_script" ]]
            then
                log::success "/commit-message command already set up in $repo_command"
                log::newline
                return 0
            fi
        fi

        log::warn "Skipping /commit-message command. Different version already exists in $repo_command"
        log::newline
    else
        mkdir -p "$(dirname "$repo_command")" "$(dirname "$repo_script")"
        cp "$src_command" "$repo_command"
        cp "$src_script" "$repo_script"
        chmod 755 "$repo_script"
        sed "s|<VALIDATE_COMMIT_SCRIPT>|$repo_script|g" "$repo_command" > "$repo_command.tmp" && mv "$repo_command.tmp" "$repo_command"
        log::success "/commit-message command written to $GIT_DIR/.opencode/commands/commit-message.md"
        log::newline
    fi
}


# ----------------------------------

log::box "System Pre-checks"
_ensure_git_project
_ensure_openspec_installed
_ensure_codebase_memory_mcp_installed
_ensure_rtk_installed

log::box "Initializing Tools"
_update_gitignore
_init_openspec
_init_codebase_memory_mcp
_init_rtk

log::box "Installing Commands"
_write_commit_message_command
_write_command "grill-me"
_write_command "handoff"

log::box "Installing Skills"
_write_skill "diagnosing-bugs"
_write_skill "codebase-design"
_write_skill "domain-modeling"
_write_skill "improve-codebase-architecture"
_write_skill "grilling"

log::box "Installing Miscellaneous"
_init_caveman_speak

echo
log::box "  •  OpenCode Setup Complete  •  "